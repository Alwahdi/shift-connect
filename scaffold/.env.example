# ============================================================================
# SyndeoCare — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Supabase (Required) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGci...your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# ── App Configuration ───────────────────────────────────────────────────────
VITE_APP_URL=https://app.syndeocare.ai
VITE_APP_NAME=SyndeoCare

# ── Monitoring (Optional) ──────────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=

# ── Email (Edge Functions) ─────────────────────────────────────────────────
# RESEND_API_KEY=re_xxx  (set as Supabase secret, not here)

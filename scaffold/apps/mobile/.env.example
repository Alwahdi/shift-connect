# ============================================================================
# SyndeoCare Mobile — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
# Variables MUST be prefixed with EXPO_PUBLIC_ to be available in the app.

# ── Supabase (Required) ─────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key
EXPO_PUBLIC_SUPABASE_PROJECT_ID=your-project-id

# ── App Configuration ───────────────────────────────────────────────────────
EXPO_PUBLIC_APP_URL=https://app.syndeocare.ai

# ── Monitoring (Optional) ──────────────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=

# ── EAS Configuration ──────────────────────────────────────────────────────
EAS_PROJECT_ID=your-eas-project-id

{
  "extends": "../../tooling/typescript/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@syndeocare/config": ["../../packages/config/src/index.ts"],
      "@syndeocare/config/*": ["../../packages/config/src/*"],
      "@syndeocare/database": ["../../packages/database/src/index.ts"],
      "@syndeocare/database/*": ["../../packages/database/src/*"],
      "@syndeocare/design-tokens": ["../../packages/design-tokens/src/tokens.ts"],
      "@syndeocare/i18n": ["../../packages/i18n/src/index.ts"],
      "@syndeocare/storage": ["../../packages/storage/src/index.ts"],
      "@syndeocare/analytics": ["../../packages/analytics/src/index.ts"],
      "@syndeocare/ui-native": ["../../packages/ui-native/src/index.ts"],
      "@syndeocare/ui-native/*": ["../../packages/ui-native/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "app.config.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js"
  ]
}

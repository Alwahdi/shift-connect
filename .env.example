###############################################################################
# SyndeoCare – Self-Hosted Configuration
#
# 1. Copy this file:   cp .env.example .env
# 2. Fill in every value marked  ← CHANGE THIS
# 3. Run:              docker compose up -d
#
# ⚠  Never commit your real .env file to version control.
###############################################################################

# ── Public URL ────────────────────────────────────────────────────────────────
# The URL at which the Supabase API (Kong) will be publicly accessible.
# For local dev:    http://localhost:8000
# For a server:     https://api.yourdomain.com
API_EXTERNAL_URL=http://localhost:8000

# The URL at which the SyndeoCare web app will be publicly accessible.
# For local dev:    http://localhost
# For a server:     https://yourdomain.com
SITE_URL=http://localhost

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-super-secret-postgres-password    # ← CHANGE THIS

# ── JWT / API keys ────────────────────────────────────────────────────────────
# Generate a strong random secret (min 32 chars):
#   openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long   # ← CHANGE THIS

# The ANON_KEY and SERVICE_ROLE_KEY must be JWTs signed with JWT_SECRET.
# Use https://supabase.com/docs/guides/self-hosting#api-keys to generate them,
# or the helper script:  node scripts/generate-keys.js
#
# Default LOCAL-ONLY development keys (DO NOT use in production):
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqd6PQgIWi3fLXSRSXBxJq7M0HYt03q30
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0

# JWT expiry in seconds (default 1 hour)
JWT_EXPIRY=3600

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
# Required for OTP verification emails and notification emails.
RESEND_API_KEY=re_your_resend_api_key_here    # ← CHANGE THIS

# ── SMTP (optional – used by GoTrue for auth emails) ──────────────────────────
# If left blank, GoTrue will attempt to use the built-in Inbucket test inbox.
SMTP_ADMIN_EMAIL=admin@syndeocare.ai
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=SyndeoCare

# ── Auth settings ─────────────────────────────────────────────────────────────
# Set to true to skip email confirmation (dev only)
ENABLE_EMAIL_AUTOCONFIRM=false
# Set to true to prevent new sign-ups
DISABLE_SIGNUP=false
# Comma-separated list of extra redirect URLs allowed by GoTrue
ADDITIONAL_REDIRECT_URLS=

# ── Ports (change if something is already using these on your host) ───────────
FRONTEND_PORT=80
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
STUDIO_PORT=3000

# ── Realtime ──────────────────────────────────────────────────────────────────
# Generate a random base64 secret:  openssl rand -base64 64
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq   # ← CHANGE THIS

# ── Studio ────────────────────────────────────────────────────────────────────
STUDIO_DEFAULT_ORGANIZATION=SyndeoCare
STUDIO_DEFAULT_PROJECT=SyndeoCare

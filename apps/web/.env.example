# SyndeoCare Web Frontend — Environment Variables
# ─────────────────────────────────────────────────
# Copy this file: cp .env.example .env.local
# Then fill in the values for your environment.
#
# ⚠️  NEVER commit .env.local to git.

# ─── API Gateway ─────────────────────────────────────────────────────────────
# Base URL of the NestJS API gateway (nginx proxy).
# All REST API calls from the frontend are routed through here.
VITE_API_URL=http://localhost:8080

# ─── Legacy Supabase (migration period only) ─────────────────────────────────
# These are used by the Supabase client during the incremental migration.
# Once the auth context and all data hooks have been migrated to the API
# gateway, these variables can be removed.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_KEY

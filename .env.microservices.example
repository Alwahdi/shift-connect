# SyndeoCare Microservices — Environment Variables
# ──────────────────────────────────────────────────
# Copy this file: cp .env.microservices.example .env.microservices
# Then fill in EVERY value before starting the stack.
#
# ⚠️  NEVER commit .env.microservices to git.

# ─── Node ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Single Postgres instance; init.sh creates one database per service:
#   auth_db, users_db, bookings_db, notifications_db, payments_db, admin_db
POSTGRES_USER=syndeocare
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# POSTGRES_DB is the superuser connection database (used only during init)
POSTGRES_DB=postgres
POSTGRES_EXTERNAL_PORT=5432

# Each service DATABASE_URL is hardcoded in docker-compose.microservices.yml
# using the pattern: postgres://<user>:<password>@postgres:5432/<service>_db
# You do NOT need to set DATABASE_URL here.

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_EXTERNAL_PORT=6379

# ─── JWT Secrets (min 32 chars each) ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO (local S3) ─────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REPLACE_WITH_MINIO_PASSWORD
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET_NAME=syndeocare
S3_REGION=us-east-1

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_UI_PORT=8090

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your key at https://resend.com
RESEND_API_KEY=re_REPLACE_WITH_YOUR_RESEND_KEY
OTP_TTL_SECONDS=300

# ─── Payments (Stripe) ───────────────────────────────────────────────────────
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_STRIPE_WEBHOOK_SECRET

# ─── Ports ────────────────────────────────────────────────────────────────────
FRONTEND_PORT=80
GATEWAY_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3100
LOKI_PORT=3200

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD

{
  "buildCommand": "npx storybook build -o public/storybook && npm run build",
  "rewrites": [
    { "source": "/storybook", "destination": "/storybook/index.html" },
    { "source": "/storybook/(.*)", "destination": "/storybook/$1" },
    { "source": "/((?!storybook).*)", "destination": "/" }
  ]
}
